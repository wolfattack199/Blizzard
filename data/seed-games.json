  {
    "title": "Snake",
    "description": "The classic snake game. Use arrow keys, don't hit yourself.",
    "thumb": "🐍",
    "code": "<!doctype html><html><head><meta charset='utf-8'><title>Snake</title><style>body{margin:0;background:#0b1220;color:#eaf2ff;font-family:system-ui,sans-serif;text-align:center}canvas{background:#050912;border:1px solid #243352;margin-top:20px}</style></head><body><h2 style='color:#7cc7ff'>Snake · Arrow keys</h2><canvas id='c' width='400' height='400'></canvas><script>const c=document.getElementById('c'),x=c.getContext('2d');const S=20;let snake=[{x:10,y:10}],dx=1,dy=0,food={x:5,y:5},score=0,dead=false;addEventListener('keydown',e=>{if(e.key==='ArrowUp'&&dy===0){dx=0;dy=-1}if(e.key==='ArrowDown'&&dy===0){dx=0;dy=1}if(e.key==='ArrowLeft'&&dx===0){dx=-1;dy=0}if(e.key==='ArrowRight'&&dx===0){dx=1;dy=0}});function tick(){if(dead)return;const h={x:snake[0].x+dx,y:snake[0].y+dy};if(h.x<0||h.y<0||h.x>=20||h.y>=20||snake.some(s=>s.x===h.x&&s.y===h.y)){dead=true;x.fillStyle='rgba(0,0,0,0.7)';x.fillRect(0,0,400,400);x.fillStyle='#fff';x.font='28px system-ui';x.fillText('Game Over · '+score,110,200);return}snake.unshift(h);if(h.x===food.x&&h.y===food.y){score++;food={x:Math.floor(Math.random()*20),y:Math.floor(Math.random()*20)}}else snake.pop();x.fillStyle='#050912';x.fillRect(0,0,400,400);x.fillStyle='#ff6b7a';x.fillRect(food.x*S,food.y*S,S,S);x.fillStyle='#5aa9ff';snake.forEach(s=>x.fillRect(s.x*S,s.y*S,S-1,S-1))}setInterval(tick,120);</script></body></html>"
  }
