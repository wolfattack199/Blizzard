  {
    "title": "Snowball Catch",
    "description": "Move the basket left and right to catch falling snowballs. Don't miss too many!",
    "thumb": "❄",
    "code": "<!doctype html><html><head><meta charset='utf-8'><title>Snowball Catch</title><style>html,body{margin:0;background:#0b1220;color:#eaf2ff;font-family:system-ui,sans-serif;height:100%;overflow:hidden}canvas{display:block;margin:0 auto;background:linear-gradient(180deg,#0b1220,#1a2b54)}h2{margin:10px;text-align:center;color:#7cc7ff}p{margin:0 10px 8px;text-align:center;color:#aab}</style></head><body><h2>Snowball Catch</h2><p>← → to move · catch snowballs · 3 misses and you're out</p><canvas id='c' width='600' height='400'></canvas><script>const c=document.getElementById('c'),x=c.getContext('2d');let px=275,score=0,miss=0,balls=[];const keys={};addEventListener('keydown',e=>keys[e.key]=1);addEventListener('keyup',e=>keys[e.key]=0);function spawn(){balls.push({x:Math.random()*580+10,y:-10,v:2+Math.random()*3})}setInterval(spawn,700);function loop(){x.clearRect(0,0,600,400);if(keys.ArrowLeft)px-=5;if(keys.ArrowRight)px+=5;px=Math.max(0,Math.min(550,px));x.fillStyle='#7cc7ff';x.fillRect(px,370,50,12);for(const b of balls){b.y+=b.v;x.fillStyle='#fff';x.beginPath();x.arc(b.x,b.y,8,0,7);x.fill()}balls=balls.filter(b=>{if(b.y>370&&b.x>px&&b.x<px+50){score++;return false}if(b.y>400){miss++;return false}return true});x.fillStyle='#eaf2ff';x.font='16px system-ui';x.fillText('Score: '+score,10,22);x.fillText('Misses: '+miss+'/3',500,22);if(miss>=3){x.fillStyle='rgba(0,0,0,0.7)';x.fillRect(0,0,600,400);x.fillStyle='#fff';x.font='32px system-ui';x.fillText('Game Over · Score '+score,140,210)}else requestAnimationFrame(loop)}loop();</script></body></html>"
  },
  {
    "title": "Tic-Tac-Toe",
    "description": "Classic two-player tic-tac-toe. Take turns clicking squares.",
    "thumb": "✕",
    "code": "<!doctype html><html><head><meta charset='utf-8'><title>Tic-Tac-Toe</title><style>body{margin:0;background:#0b1220;color:#eaf2ff;font-family:system-ui,sans-serif;display:flex;flex-direction:column;align-items:center;padding-top:30px}.b{display:grid;grid-template-columns:repeat(3,90px);gap:6px;margin:14px}.s{width:90px;height:90px;background:#19243d;border:1px solid #243352;font-size:48px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#7cc7ff}.s:hover{background:#243352}h1{font-weight:300;letter-spacing:2px;color:#7cc7ff}#st{margin-top:10px}button{padding:8px 16px;background:#5aa9ff;color:#06122a;border:none;border-radius:6px;cursor:pointer;font-weight:600}</style></head><body><h1>Tic-Tac-Toe</h1><div class='b' id='b'></div><div id='st'>X's turn</div><br><button onclick='reset()'>Restart</button><script>let bd=Array(9).fill(''),t='X',over=false;const b=document.getElementById('b'),st=document.getElementById('st');function r(){b.innerHTML='';bd.forEach((v,i)=>{const d=document.createElement('div');d.className='s';d.textContent=v;d.onclick=()=>play(i);b.appendChild(d)})}function play(i){if(over||bd[i])return;bd[i]=t;const w=check();if(w){st.textContent=w==='draw'?\"Draw!\":w+' wins!';over=true}else{t=t==='X'?'O':'X';st.textContent=t+\"'s turn\"}r()}function check(){const L=[[0,1,2],[3,4,5],[6,7,8],[0,3,6],[1,4,7],[2,5,8],[0,4,8],[2,4,6]];for(const l of L){const[a,b,c]=l;if(bd[a]&&bd[a]===bd[b]&&bd[b]===bd[c])return bd[a]}return bd.every(x=>x)?'draw':null}function reset(){bd=Array(9).fill('');t='X';over=false;st.textContent=\"X's turn\";r()}r();</script></body></html>"
